{
  "extends": "next/core-web-vitals",
  "rules": {
    "no-restricted-imports": [
      "error",
      {
        "patterns": [
          {
            "group": ["*/llm-provider/openrouter*", "*/llm-provider/cli/*"],
            "message": "Import LLM functionality through lib/llm-client.ts, not directly from providers."
          }
        ]
      }
    ]
  },
  "overrides": [
    {
      "files": ["lib/llm-client.ts", "lib/llm-provider/**/*"],
      "rules": {
        "no-restricted-imports": "off"
      }
    },
    {
      "files": [
        "lib/__tests__/llm-provider-*.test.ts",
        "lib/__tests__/llm-tools-runner.test.ts",
        "lib/__tests__/llm-tools-runner-cli.test.ts",
        "lib/__tests__/host-token-sync.test.ts"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ]
}
