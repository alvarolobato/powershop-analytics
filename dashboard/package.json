{
  "name": "powershop-dashboard",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "next dev -p ${DASHBOARD_PORT:-4000}",
    "build:knowledge": "tsx scripts/build-knowledge.ts",
    "prebuild": "[ ! -f ../docs/etl-sync-strategy.md ] || npm run build:knowledge",
    "build": "next build",
    "start": "next start -p ${DASHBOARD_PORT:-4000}",
    "lint": "next lint",
    "lint:conversation-dedup": "bash scripts/lint-conversation-dedup.sh",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.4",
    "@tremor/react": "^3.18.7",
    "@types/prismjs": "^1.26.6",
    "next": "^14.2.29",
    "openai": "^6.33.0",
    "pg": "^8.20.0",
    "prismjs": "^1.30.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-simple-code-editor": "^0.14.1",
    "remark-gfm": "^4.0.1",
    "sql-formatter": "^15.7.3",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20.19.39",
    "@types/pg": "^8.20.0",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "autoprefixer": "^10.4.21",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.29",
    "jsdom": "^29.0.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "vitest": "^4.1.4"
  }
}
