# =============================================================================
# PowerShop Analytics — environment variables
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# .env is git-ignored; never commit real credentials.
# =============================================================================

# -----------------------------------------------------------------------------
# Release channel (production / docker-compose.prod.yml only)
# -----------------------------------------------------------------------------
# Image tags to pull from Docker Hub. Use 'beta' for the nightly beta channel
# or 'latest' / a pinned version like 'v0.1.0' for stable.
ETL_VERSION=latest
DASHBOARD_VERSION=latest
# Override if you publish to a different Docker Hub namespace.
# DOCKERHUB_NAMESPACE=alobato

# Interface to bind host ports on. 0.0.0.0 = reachable on every network
# interface (LAN). 127.0.0.1 = loopback only (useful behind a reverse proxy).
HOST_BIND=0.0.0.0

# -----------------------------------------------------------------------------
# 4D Database (source ERP — read-only access)
# -----------------------------------------------------------------------------
P4D_HOST=your_4d_server_ip
P4D_PORT=19812
P4D_USER=
P4D_PASSWORD=

# -----------------------------------------------------------------------------
# PostgreSQL (local mirror — destination for ETL)
# -----------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=powershop
# POSTGRES_HOST and POSTGRES_PORT default to "localhost" and "5432" when unset.
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# POSTGRES_DSN overrides the split variables above (use for explicit control).
# Example: POSTGRES_DSN=postgresql://postgres:password@localhost:5432/powershop
POSTGRES_DSN=

# -----------------------------------------------------------------------------
# WrenAI LLM (via OpenRouter — https://openrouter.ai)
# -----------------------------------------------------------------------------
OPENROUTER_API_KEY=your_openrouter_api_key

# LLM model used for SQL generation (any model available on OpenRouter)
WREN_LLM_MODEL=anthropic/claude-sonnet-4

# -----------------------------------------------------------------------------
# ETL Schedule
# -----------------------------------------------------------------------------
ETL_CRON_HOUR=2

# -----------------------------------------------------------------------------
# WrenAI service versions (change to upgrade)
# -----------------------------------------------------------------------------
WREN_PRODUCT_VERSION=0.29.1
WREN_ENGINE_VERSION=0.22.0
WREN_AI_SERVICE_VERSION=0.29.0
IBIS_SERVER_VERSION=0.22.0
WREN_UI_VERSION=0.32.2
WREN_BOOTSTRAP_VERSION=0.1.5

# -----------------------------------------------------------------------------
# WrenAI internal ports (change only if you have conflicts)
# -----------------------------------------------------------------------------
WREN_ENGINE_PORT=8080
WREN_ENGINE_SQL_PORT=7432
WREN_AI_SERVICE_PORT=5555
IBIS_SERVER_PORT=8000

# Port exposed to host for WrenAI UI (default: 3000)
HOST_PORT=3000

# Port exposed to host for WrenAI AI service (default: 5555)
AI_SERVICE_FORWARD_PORT=5555

# -----------------------------------------------------------------------------
# WrenAI telemetry (optional — set TELEMETRY_ENABLED=false to opt out)
# -----------------------------------------------------------------------------
TELEMETRY_ENABLED=true
USER_UUID=
POSTHOG_API_KEY=phc_nhF32aj4xHXOZb0oqr2cn4Oy9uiWzz6CCP4KZmRq9aE
POSTHOG_HOST=https://app.posthog.com

# -----------------------------------------------------------------------------
# WrenAI misc
# -----------------------------------------------------------------------------
PLATFORM=linux/amd64
EXPERIMENTAL_ENGINE_RUST_VERSION=false

# Optional: Langfuse observability
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=

# -----------------------------------------------------------------------------
# Dashboard App (AI-generated dashboards)
# -----------------------------------------------------------------------------
# Port exposed to host for Dashboard App (default: 4000)
DASHBOARD_PORT=4000

# LLM model for dashboard generation (any model available on OpenRouter)
DASHBOARD_LLM_MODEL=anthropic/claude-sonnet-4

# Shared secret for /api/admin/* (x-admin-key or Authorization: Bearer) and /admin/* UI cookie login.
# Use a long random string in production.
# ADMIN_API_KEY=

# Optional daily spend cap for LLM calls in USD (e.g. 5.00); unset = no limit
# LLM_DAILY_BUDGET_USD=5.00

# -----------------------------------------------------------------------------
# Docker Hub (used by GitHub Actions to push ETL images)
# -----------------------------------------------------------------------------
DOCKERHUB_USERNAME=your_dockerhub_username
DOCKERHUB_TOKEN=your_dockerhub_access_token
