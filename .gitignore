# Python
.venv/
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/

# Local credentials (never commit)
local/

# Environment files (contain secrets — .env.example is committed, .env is not)
.env
.env.local

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Generated reports and sample data (contain real business data)
docs/reports/*.html
docs/reports/*.json
docs/sample-data/

# Persistent bind-mount data (Docker volumes — never commit)
data/

# Dashboard App
dashboard/node_modules/
dashboard/.next/
dashboard/tsconfig.tsbuildinfo

# Runtime/temp
*.log
tmp/
_*.py
!__init__.py
_*.json
