#!/usr/bin/env bash
# PowerShop Analytics — CLI wrapper
# Manages the self-hosted analytics stack via docker compose.
#
# Usage: ps-analytics <command> [args]
#
# Installation:  run deploy/install.sh — it places this script in
#                /usr/local/bin/ps-analytics or ~/.local/bin/ps-analytics
#
set -euo pipefail

# ---------------------------------------------------------------------------
# Project directory — installer may override this line
# ---------------------------------------------------------------------------
PS_ANALYTICS_HOME="${PS_ANALYTICS_HOME:-$HOME/.powershop-analytics}"
readonly PROJECT_DIR="$PS_ANALYTICS_HOME"

ENV_FILE="${PROJECT_DIR}/.env"
COMPOSE_FILE="${PROJECT_DIR}/docker-compose.yml"
VERSION_FILE="${PROJECT_DIR}/.version"

REPO="alvarolobato/powershop-analytics"
API_BASE="https://api.github.com/repos/${REPO}"
RELEASE_BASE="https://github.com/${REPO}/releases/download"

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------
info()    { printf '\033[1;34m[INFO]\033[0m  %s\n' "$*"; }
success() { printf '\033[1;32m[OK]\033[0m    %s\n' "$*"; }
warn()    { printf '\033[1;33m[WARN]\033[0m  %s\n' "$*"; }
die()     { printf '\033[1;31m[ERROR]\033[0m %s\n' "$*" >&2; exit 1; }

require_project_dir() {
  if [[ ! -d "$PROJECT_DIR" ]]; then
    die "Project directory not found: ${PROJECT_DIR}\nRun the installer first: https://github.com/${REPO}#installation"
  fi
  if [[ ! -f "$COMPOSE_FILE" ]]; then
    die "docker-compose.yml not found in ${PROJECT_DIR}. Re-run the installer."
  fi
  if [[ ! -f "$ENV_FILE" ]]; then
    die ".env not found in ${PROJECT_DIR}. Run: ps-analytics setup"
  fi
}

load_env() {
  # shellcheck source=/dev/null
  set -a; source "$ENV_FILE"; set +a
}

dc() {
  docker compose -f "$COMPOSE_FILE" --env-file "$ENV_FILE" "$@"
}

# ---------------------------------------------------------------------------
# Commands
# ---------------------------------------------------------------------------
cmd_setup() {
  info "Re-running .env configuration..."
  if [[ -f "$ENV_FILE" ]]; then
    warn "Existing .env found. Backing up to .env.bak"
    cp "$ENV_FILE" "${ENV_FILE}.bak"
  fi

  prompt_required() {
    local label="$1" value=""
    while [[ -z "$value" ]]; do read -rp "  ${label}: " value; done
    printf '%s' "$value"
  }
  prompt_default() {
    local label="$1" default="$2" value=""
    read -rp "  ${label} [${default}]: " value
    printf '%s' "${value:-$default}"
  }
  random_password() {
    if command -v openssl &>/dev/null; then
      openssl rand -base64 18 | tr -dc 'A-Za-z0-9' | head -c 24
    else
      tr -dc 'A-Za-z0-9' </dev/urandom | head -c 24
    fi
  }

  local pg_pass; pg_pass=$(random_password)
  local p4d_host p4d_user p4d_password postgres_password openrouter_key

  echo ""
  info "Configure .env — press Enter to accept defaults."
  echo ""
  p4d_host=$(prompt_required "4D server hostname or IP")
  p4d_user=$(prompt_required "4D SQL username")
  p4d_password=$(prompt_required "4D SQL password")
  postgres_password=$(prompt_default "PostgreSQL password" "$pg_pass")
  openrouter_key=$(prompt_required "OpenRouter API key (for WrenAI LLM)")

  cat >"$ENV_FILE" <<EOF
# PowerShop Analytics — environment configuration
# Generated by ps-analytics setup on $(date -u +"%Y-%m-%dT%H:%M:%SZ")

P4D_HOST=${p4d_host}
P4D_PORT=19812
P4D_USER=${p4d_user}
P4D_PASSWORD=${p4d_password}
SOAP_URL=http://${p4d_host}:8080/4DSOAP/
SOAP_WSDL=http://${p4d_host}:8080/4DSOAP/?wsdl
POSTGRES_USER=postgres
POSTGRES_PASSWORD=${postgres_password}
POSTGRES_DB=powershop
ETL_CRON_HOUR=2
OPENROUTER_API_KEY=${openrouter_key}
WREN_LLM_MODEL=openrouter/anthropic/claude-sonnet-4-20250514
HOST_PORT=3000
WREN_BOOTSTRAP_VERSION=0.1.5
WREN_ENGINE_VERSION=0.22.0
IBIS_SERVER_VERSION=0.22.0
WREN_AI_SERVICE_VERSION=0.29.0
WREN_UI_VERSION=0.32.2
WREN_PRODUCT_VERSION=0.29.1
AI_SERVICE_FORWARD_PORT=5555
WREN_ENGINE_PORT=8080
WREN_ENGINE_SQL_PORT=7432
IBIS_SERVER_PORT=8000
WREN_AI_SERVICE_PORT=5555
PLATFORM=linux/amd64
TELEMETRY_ENABLED=true
EOF
  success ".env written to ${ENV_FILE}"
}

cmd_up() {
  require_project_dir
  info "Starting stack..."
  dc up -d
  success "Stack started. Run: ps-analytics status"
}

cmd_down() {
  require_project_dir
  info "Stopping stack..."
  dc down
  success "Stack stopped."
}

cmd_restart() {
  require_project_dir
  info "Restarting stack..."
  dc restart
  success "Stack restarted."
}

cmd_status() {
  require_project_dir
  dc ps
  echo ""
  load_env
  local port="${HOST_PORT:-3000}"
  if curl -fsSL --max-time 3 "http://localhost:${port}" &>/dev/null; then
    success "WrenAI UI is reachable at http://localhost:${port}"
  else
    warn "WrenAI UI not responding yet at http://localhost:${port} (may still be starting)"
  fi
}

cmd_logs() {
  require_project_dir
  local service="${1:-}"
  if [[ -n "$service" ]]; then
    dc logs -f "$service"
  else
    dc logs -f
  fi
}

cmd_etl() {
  require_project_dir
  local sub="${1:-help}"
  shift || true

  case "$sub" in
    run)
      info "Running ETL sync (one-off)..."
      dc run --rm etl python -m etl.main --once
      ;;
    status)
      load_env
      info "ETL watermarks (last sync per table):"
      dc exec -T postgres psql \
        -U "${POSTGRES_USER:-postgres}" \
        -d "${POSTGRES_DB:-powershop}" \
        -c "SELECT table_name, last_value, updated_at FROM etl_watermarks ORDER BY table_name;"
      ;;
    tables)
      load_env
      info "Row counts for synced tables (ps_*):"
      dc exec -T postgres psql \
        -U "${POSTGRES_USER:-postgres}" \
        -d "${POSTGRES_DB:-powershop}" \
        -c "SELECT schemaname, relname AS table_name, n_live_tup AS row_count
            FROM pg_stat_user_tables
            WHERE relname LIKE 'ps_%'
            ORDER BY relname;"
      ;;
    logs)
      dc logs -f etl
      ;;
    *)
      echo "Usage: ps-analytics etl {run|status|tables|logs}"
      exit 1
      ;;
  esac
}

cmd_update() {
  require_project_dir
  info "Checking for updates..."

  local latest
  latest=$(curl -fsSL "${API_BASE}/releases/latest" | grep '"tag_name"' | sed -E 's/.*"tag_name": *"([^"]+)".*/\1/')
  if [[ -z "$latest" ]]; then
    die "Could not determine latest release."
  fi

  local current=""
  if [[ -f "$VERSION_FILE" ]]; then
    current=$(cat "$VERSION_FILE")
  fi

  if [[ "$latest" == "$current" ]]; then
    success "Already on latest version: ${latest}"
    return
  fi

  info "Updating from ${current:-unknown} to ${latest}..."

  # Download updated compose and config
  curl -fsSL "${RELEASE_BASE}/${latest}/docker-compose.prod.yml" -o "${PROJECT_DIR}/docker-compose.yml"
  curl -fsSL "${RELEASE_BASE}/${latest}/wren-config.yaml"        -o "${PROJECT_DIR}/wren-config.yaml"
  success "Stack files updated"

  # Update CLI wrapper (replace self)
  local tmp_cli; tmp_cli=$(mktemp)
  curl -fsSL "${RELEASE_BASE}/${latest}/ps-analytics" -o "$tmp_cli"
  chmod +x "$tmp_cli"
  # Preserve project dir override if any
  sed -i.bak "s|^PS_ANALYTICS_HOME=.*|PS_ANALYTICS_HOME=\"${PROJECT_DIR}\"|" "$tmp_cli" 2>/dev/null || true
  rm -f "${tmp_cli}.bak"
  # Replace self (works on Linux; macOS may need cp+rm dance)
  local self; self="$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || realpath "${BASH_SOURCE[0]}" 2>/dev/null || echo "${BASH_SOURCE[0]}")"
  if [[ -w "$self" ]]; then
    install -m 0755 "$tmp_cli" "$self"
  else
    sudo install -m 0755 "$tmp_cli" "$self"
  fi
  rm -f "$tmp_cli"
  success "CLI wrapper updated"

  # Pull new images and restart
  info "Pulling updated images..."
  dc pull

  info "Restarting stack..."
  dc down
  dc up -d

  echo "$latest" >"$VERSION_FILE"
  success "Updated to ${latest}"
}

cmd_destroy() {
  require_project_dir
  warn "This will STOP all containers, remove volumes, and DELETE data in ${PROJECT_DIR}/data/"
  warn "This action is IRREVERSIBLE."
  read -rp "  Type 'yes' to confirm: " confirm
  if [[ "$confirm" != "yes" ]]; then
    info "Aborted."
    exit 0
  fi

  dc down -v
  rm -rf "${PROJECT_DIR}/data"
  success "Stack destroyed and data removed."
}

cmd_open() {
  require_project_dir
  load_env
  local port="${HOST_PORT:-3000}"
  local url="http://localhost:${port}"
  info "Opening ${url}"

  case "$(uname -s)" in
    Darwin) open "$url" ;;
    Linux)
      if command -v xdg-open &>/dev/null; then
        xdg-open "$url"
      elif command -v wslview &>/dev/null; then
        wslview "$url"
      else
        info "Could not detect browser launcher. Open manually: ${url}"
      fi
      ;;
    *) info "Open manually: ${url}" ;;
  esac
}

cmd_version() {
  local version="unknown"
  if [[ -f "$VERSION_FILE" ]]; then
    version=$(cat "$VERSION_FILE")
  fi
  echo "ps-analytics ${version}"
}

cmd_help() {
  cat <<'HELP'
PowerShop Analytics CLI

Usage: ps-analytics <command> [args]

Stack management:
  up              Start all containers in the background
  down            Stop all containers
  restart         Restart all containers
  status          Show container status and WrenAI UI health
  logs [service]  Follow logs (optionally for a specific service)
  open            Open WrenAI UI in browser

ETL operations:
  etl run         Run a one-off ETL sync
  etl status      Show watermark table (last sync per table)
  etl tables      Show row counts for synced tables (ps_*)
  etl logs        Follow ETL container logs

Maintenance:
  setup           (Re-)configure .env interactively
  update          Fetch latest release, update stack files, restart
  destroy         Stop containers and delete all data (irreversible)
  version         Print installed version
  help            Print this help

Project directory: configured via PS_ANALYTICS_HOME env var or install.sh
HELP
}

# ---------------------------------------------------------------------------
# Dispatch
# ---------------------------------------------------------------------------
COMMAND="${1:-help}"
shift || true

case "$COMMAND" in
  setup)    cmd_setup ;;
  up)       cmd_up ;;
  down)     cmd_down ;;
  restart)  cmd_restart ;;
  status)   cmd_status ;;
  logs)     cmd_logs "${1:-}" ;;
  etl)      cmd_etl "${@}" ;;
  update)   cmd_update ;;
  destroy)  cmd_destroy ;;
  open)     cmd_open ;;
  version)  cmd_version ;;
  help|-h|--help) cmd_help ;;
  *)
    warn "Unknown command: ${COMMAND}"
    cmd_help
    exit 1
    ;;
esac
